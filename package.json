{
  "name": "webscrape-workbench",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "author": {
    "name": "LopAshraff",
    "url": "https://github.com/LopAshraff"
  },
  "description": "CLI-first local web scraping utility for saving clean content, metadata, and assets from URLs.",
  "homepage": "https://github.com/LopAshraff/webscrape-workbench",
  "repository": {
    "type": "git",
    "url": "https://github.com/LopAshraff/webscrape-workbench.git"
  },
  "bugs": {
    "url": "https://github.com/LopAshraff/webscrape-workbench/issues"
  },
  "main": "electron/main.cjs",
  "bin": {
    "webscrape": "./src/cli.js"
  },
  "scripts": {
    "app": "node src/app-server.js",
    "cert:dev": "pwsh -ExecutionPolicy Bypass -File scripts/setup-dev-code-signing-cert.ps1",
    "desktop": "electron .",
    "dist:win": "electron-builder --win nsis --config electron-builder.config.mjs",
    "dist:win:signed": "pwsh -ExecutionPolicy Bypass -File scripts/build-signed-win.ps1",
    "start": "node src/cli.js",
    "scrape": "node src/cli.js",
    "smoke": "node tests/smoke.js && node tests/crawl-smoke.js && node tests/profile-smoke.js"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.1.2",
    "commander": "^14.0.1",
    "jsdom": "^27.0.0",
    "p-limit": "^7.1.1",
    "playwright": "^1.54.2",
    "turndown": "^7.2.1"
  },
  "devDependencies": {
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1"
  }
}
